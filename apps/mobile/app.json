{
  "expo": {
    "name": "Cromos 26",
    "slug": "pablo-app",
    "version": "1.0.0",
    "scheme": "cromos26",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pabloapp.mundial2026",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["com.googleusercontent.apps.101210295525-acth5d6aubeg2sqotr8m4l08bk62b4mb"]
          }
        ]
      }
    },
    "android": {
      "package": "com.pabloapp.mundial2026",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Para acceder a la app de forma segura."
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-crypto",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Cromos 26 to access your photos so you can create a custom Panini sticker.",
          "cameraPermission": "Allow Cromos 26 to use your camera so you can take a selfie for your custom sticker."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.101210295525-acth5d6aubeg2sqotr8m4l08bk62b4mb"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "732ed138-a83a-41dc-8886-4f8217289d4f"
      }
    },
    "owner": "brankostula",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/732ed138-a83a-41dc-8886-4f8217289d4f",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 8000
    }
  }
}
