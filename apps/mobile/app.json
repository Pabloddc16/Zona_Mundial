{
  "expo": {
    "name": "Pablo App",
    "slug": "pablo-app",
    "version": "1.0.0",
    "scheme": "pablo",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#006341"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pabloapp.mundial2026",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.pabloapp.mundial2026",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#006341"
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-haptics",
      "expo-notifications",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Para acceder a la app de forma segura." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
