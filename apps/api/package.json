{
  "name": "@pablo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:admin": "tsx --env-file=.env.local scripts/seed-admin.ts",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/csrf-protection": "^6.4.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@pablo/db": "workspace:*",
    "@pablo/types": "workspace:*",
    "@pablo/validators": "workspace:*",
    "@sentry/node": "^8.55.2",
    "@supabase/supabase-js": "^2.105.1",
    "backblaze-b2": "^1.7.0",
    "bcrypt": "^5.1.1",
    "fastify": "^4.28.0",
    "fastify-plugin": "^5.1.0",
    "otplib": "^12.0.1",
    "pino": "^9.14.0",
    "qrcode": "^1.5.4",
    "resend": "^3.5.0",
    "stripe": "^22.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^2.1.4",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.15.0",
    "typescript": "*",
    "vitest": "^2.1.4"
  }
}
