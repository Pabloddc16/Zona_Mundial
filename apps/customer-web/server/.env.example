# Mundial 26 server — copy to .env and fill in.

PORT=3001

# Public URL where this backend is reachable (Mercado Pago will POST webhooks here).
# In dev, expose via ngrok / cloudflared and put the public URL here.
BACKEND_URL=https://your-public-tunnel.example.com

# Public URL where the SPA is served. MP redirects users back here.
APP_URL=http://localhost:5173

# Mercado Pago — sandbox (TEST-...) or production. Keep this secret.
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-000000000

# Webhook signing secret from MP dashboard (optional in pure dev — required in prod).
MP_WEBHOOK_SECRET=

# Path to the JSON-file DB. Default ./data/db.json (relative to /server).
DB_PATH=
