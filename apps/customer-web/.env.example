# Mundial 26 — environment variables
#
# Copia este archivo a .env.local y rellena los valores.
# Las vars con prefijo VITE_ se exponen al bundle del navegador.

# Sentry — observabilidad de errores en producción.
# Si está vacío, Sentry no se inicializa (modo dev sin telemetría).
VITE_SENTRY_DSN=

# Backend que crea preferencias de Mercado Pago. Sin slash final.
# En dev típicamente http://localhost:3001
VITE_BACKEND_URL=http://localhost:3001

# Supabase — sincroniza swaps en vivo entre dos usuarios.
# Si están vacíos, los swaps caen al modo "QR de recibo" (sin red).
#   1) Crea un proyecto en https://supabase.com (free tier).
#   2) Settings → API → copia "Project URL" y "anon public" key.
#   3) SQL Editor → pega server/sql/001_swaps.sql → Run.
#   4) Pega los valores aquí (y como env vars en Netlify).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
